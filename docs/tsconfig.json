{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "composite": true,
    "incremental": true,
    "jsx": "preserve",
    "module": "ESNext",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "strictNullChecks": true,
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },
  "include": ["next-env.d.ts", "app/**/*.ts", "app/**/*.tsx", "proxy.ts"],
  "exclude": ["node_modules"],
  "references": [{ "path": "../tsconfig.lib.json" }]
}
