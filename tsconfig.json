{
  "compilerOptions": {
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "better-og": ["packages/better-og/src/index.ts"],
      "@better-og/edge": ["packages/edge/src/index.ts"],
      "@better-og/next": ["packages/next/src/index.ts"],
      "@better-og/next/edge": ["packages/next/src/edge.ts"],
      "@better-og/tanstack-start": ["packages/tanstack-start/src/index.ts"],
      "@better-og/workers": ["packages/workers/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  }
}
