{
  "name": "@better-og/core",
  "version": "0.1.0",
  "description": "Core Open Graph context, safe-area, and font helpers for the better-og workspace.",
  "keywords": [
    "aspect-ratio",
    "fonts",
    "image-response",
    "og",
    "open-graph",
    "takumi"
  ],
  "homepage": "https://github.com/Aniket-508/better-og/tree/main/packages/better-og#readme",
  "bugs": {
    "url": "https://github.com/Aniket-508/better-og/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aniket-508/better-og.git",
    "directory": "packages/better-og"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#core": "./src/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm clean && NODE_ENV=production tsdown",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --pretty && tsc -p tests/tsconfig.json --pretty",
    "test": "pnpm build && vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsdown": "^0.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.20.0",
    "pnpm": ">=10.29.1"
  },
  "packageManager": "pnpm@10.29.1"
}
